{
  "name": "@zuzjs/hooks",
  "version": "0.1.21",
  "description": "ZuzJS Hooks",
  "keywords": [
    "react",
    "zuz",
    "zuz.js",
    "zuz ui",
    "zuzui"
  ],
  "homepage": "https://hooks.zuz.com.pk",
  "bugs": {
    "url": "https://github.com/zuzpk/zuzjs-hooks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zuzpk/zuzjs-hooks.git"
  },
  "license": "MIT",
  "author": "Zuz.js Team <support@zuz.com.pk>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev:js": "tsup --watch",
    "dev": "npm-run-all -p dev:*",
    "build": "rm -rf dist && tsup",
    "prepare": "husky",
    "publish": "npm run build && node publish-pre.js && npm publish && node publish-post.js"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@types/md5": "^2.3.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@zuzjs/core": "workspace:*",
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "dashjs": "^5.1.1",
    "date-fns": "^4.1.0",
    "hashids": "^2.3.0",
    "js-cookie": "^3.0.5",
    "md5": "^2.3.0",
    "moment": "^2.30.1",
    "nanoid": "^5.1.6",
    "picocolors": "^1.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "node-loader": "^2.1.0",
    "npm-run-all": "^4.1.5",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2"
  }
}